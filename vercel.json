{
  "version": 2,
  "name": "steppedna",
  "buildCommand": "",
  "outputDirectory": "frontend",
  "rewrites": [
    { "source": "/predict", "destination": "https://steppedna-api.onrender.com/predict" },
    { "source": "/predict/:path+", "destination": "https://steppedna-api.onrender.com/predict/:path+" },
    { "source": "/lookup/:path+", "destination": "https://steppedna-api.onrender.com/lookup/:path+" },
    { "source": "/health", "destination": "https://steppedna-api.onrender.com/health" },
    { "source": "/model_metrics", "destination": "https://steppedna-api.onrender.com/model_metrics" },
    { "source": "/umap", "destination": "https://steppedna-api.onrender.com/umap" },
    { "source": "/cohort/:path*", "destination": "https://steppedna-api.onrender.com/cohort/:path*" },
    { "source": "/history", "destination": "https://steppedna-api.onrender.com/history" },
    { "source": "/stats", "destination": "https://steppedna-api.onrender.com/stats" },
    { "source": "/metrics", "destination": "https://steppedna-api.onrender.com/metrics" },
    { "source": "/research/:path*", "destination": "https://steppedna-api.onrender.com/research/:path*" },
    { "source": "/structure/:path*", "destination": "https://steppedna-api.onrender.com/structure/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net; img-src 'self' data: blob:; connect-src 'self' https://steppedna-api.onrender.com https://eutils.ncbi.nlm.nih.gov https://gnomad.broadinstitute.org https://alphafold.ebi.ac.uk; frame-src 'none'; object-src 'none'; base-uri 'self';" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
