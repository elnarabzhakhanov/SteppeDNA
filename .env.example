# SteppeDNA Environment Variables
# Copy to .env and modify as needed

# ─── Backend ────────────────────────────────────────────────────────
# Set to "production" to require API key and use stricter settings
ENVIRONMENT=development

# API key for authenticated endpoints (required in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
STEPPEDNA_API_KEY=

# Number of Uvicorn workers (default: 2)
WORKERS=2

# Server port (default: 8000)
PORT=8000

# Rate limiting
RATE_LIMIT=60          # Max requests per window per IP
RATE_WINDOW=60         # Window size in seconds

# External API rate limit (ClinVar/gnomAD proxy, per window per IP)
EXTERNAL_RATE_LIMIT=20

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000

# Log format: "text" or "json"
LOG_FORMAT=text

# ─── Frontend ───────────────────────────────────────────────────────
# Override the backend URL for the frontend (set before loading api.js)
# STEPPEDNA_API_BASE=https://your-backend.onrender.com
